{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://loomcraft.work/schemas/products.generated.schema.json",
    "title": "LoomCraft Generated Product Catalog",
    "description": "Schema for AI-generated product catalog entries from image folders.",
    "type": "array",
    "minItems": 1,
    "items": {
        "$ref": "#/$defs/productCatalogItem"
    },
    "$defs": {
        "productCatalogItem": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "code", "description", "colors", "categories"],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 160
                },
                "code": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 80,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
                },
                "description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 2000
                },
                "colors": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/nonEmptySlugOrName"
                    }
                },
                "categories": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "$ref": "#/$defs/nonEmptySlugOrName"
                    }
                }
            }
        },
        "nonEmptySlugOrName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80,
            "pattern": "^[A-Za-z][A-Za-z0-9\\s-]*$"
        }
    }
}
