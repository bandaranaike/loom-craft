APP_NAME="Woven Wonder For Every Home"
APP_SITE=loomcraft
LOOMCRAFT_NAME="LoomCraft"
NATURESNATURE_NAME="Nature's Nature"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://loomcraft.work

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

DIALOG_ESMS_API_KEY=
DIALOG_ESMS_CALLBACK_URL=
DIALOG_ESMS_BASE_URL=https://e-sms.dialog.lk/api/v1/message-via-url
DIALOG_ESMS_SOURCE_ADDRESS=LoomCraft

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

COMMERCE_COMMISSION_RATE=100.00
COMMERCE_PRODUCTION_TIME_LARGE_CART_THRESHOLD=6
COMMERCE_PRODUCTION_TIME_SETUP_DAYS=2
COMMERCE_PRODUCTION_TIME_BUFFER_RATE=0.10
COMMERCE_PRODUCTION_TIME_DEFAULT_WEAVING_DAYS=1
COMMERCE_PRODUCTION_TIME_MAX_DISPLAY_DAYS=60
COMMERCE_PAYMENT_STRIPE_ENABLED=false
COMMERCE_PAYMENT_PAYPAL_ENABLED=true
COMMERCE_PAYMENT_PAYPAL_CARD_ENABLED=false
COMMERCE_PAYMENT_BANK_TRANSFER_ENABLED=true
COMMERCE_PAYMENT_COD_ENABLED=true

PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET
PAYPAL_BASE_URL

BROWSERSHOT_CHROME_PATH=
BROWSERSHOT_NODE_BINARY=
BROWSERSHOT_NPM_BINARY=
BROWSERSHOT_NODE_MODULE_PATH=
BROWSERSHOT_NO_SANDBOX=true
BROWSERSHOT_TIMEOUT=60

STRIPE_KEY=
STRIPE_SECRET=
